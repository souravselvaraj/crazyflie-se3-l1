<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="crazyflie">

  <!-- ================= Properties ================= -->
  <xacro:property name="robot_ns" value="crazyflie"/>
  <xacro:property name="mass_body" value="0.025"/>
  <xacro:property name="motor_mass" value="0.0008"/>

  <!-- Real Crazyflie thrust/moment constants -->
  <xacro:property name="motor_constant" value="1.28192e-08"/>  <!-- kf -->
  <xacro:property name="moment_constant" value="0.005964552"/> <!-- km -->

  <!-- Max rotor speed -->
  <xacro:property name="max_rot_velocity" value="2618"/>  <!-- ~25k RPM -->
  <xacro:property name="rotor_drag" value="8.06428e-05"/>
  <xacro:property name="rolling_moment" value="0.0000001"/>
  <xacro:property name="rotor_slowdown" value="20"/>

  <!-- ================= Base Link ================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.017425"/>
      <mass value="${mass_body}"/>
      <inertia
        ixx="1.6571710e-05"
        iyy="1.6655602e-05"
        izz="2.9261652e-05"
        ixy="8.30806e-07"
        ixz="7.18277e-07"
        iyz="1.800197e-06"/>
    </inertial>

    <!-- Stable collision -->
    <collision>
      <origin xyz="0 0 0.017425"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>

    <!-- Visual -->
    <visual>
      <origin xyz="0 0 0.017425"/>
      <geometry>
        <mesh filename="file://$(find crazyflie_description)/meshes/collada_files/cf2_assembly.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- ================= Propeller Macro ================= -->
  <xacro:macro name="crazyflie_prop" params="prop_name mesh_file">
    <link name="${prop_name}">
      <inertial>
        <mass value="${motor_mass}"/>
        <inertia
          ixx="8.33333e-09"
          iyy="1.08333e-07"
          izz="1.13333e-07"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>

      <visual>
        <geometry>
          <mesh filename="file://$(find crazyflie_description)/meshes/collada_files/${mesh_file}"/>
        </geometry>
      </visual>

      <!-- Disable collisions on props for stability -->
      <collision/>
    </link>
  </xacro:macro>

  <!-- ================= Prop Links ================= -->
  <xacro:crazyflie_prop prop_name="m1_prop" mesh_file="cw_prop.dae"/>   <!-- FL CW -->
  <xacro:crazyflie_prop prop_name="m2_prop" mesh_file="ccw_prop.dae"/>  <!-- FR CCW -->
  <xacro:crazyflie_prop prop_name="m3_prop" mesh_file="cw_prop.dae"/>   <!-- RR CW -->
  <xacro:crazyflie_prop prop_name="m4_prop" mesh_file="ccw_prop.dae"/>  <!-- RL CCW -->

  <!-- ================= Joints (Correct Geometry!) ================= -->
  <!-- Crazyflie geometry: +X forward, +Y left -->
  <joint name="body_to_m1_prop" type="continuous">
    <parent link="base_link"/>
    <child link="m1_prop"/>
    <origin xyz="0.031 0.031 0.021"/>     <!-- FRONT LEFT -->
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="body_to_m2_prop" type="continuous">
    <parent link="base_link"/>
    <child link="m2_prop"/>
    <origin xyz="0.031 -0.031 0.021"/>    <!-- FRONT RIGHT -->
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="body_to_m3_prop" type="continuous">
    <parent link="base_link"/>
    <child link="m3_prop"/>
    <origin xyz="-0.031 -0.031 0.021"/>   <!-- REAR RIGHT -->
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="body_to_m4_prop" type="continuous">
    <parent link="base_link"/>
    <child link="m4_prop"/>
    <origin xyz="-0.031 0.031 0.021"/>    <!-- REAR LEFT -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ================= Gazebo PLUGINS ================= -->
  <gazebo>
    <!-- Odometry -->
    <plugin filename="libgz-sim8-odometry-publisher-system.so"
            name="gz::sim::systems::OdometryPublisher">
      <odom_topic>${robot_ns}/odom</odom_topic>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>100</odom_publish_frequency>
      <dimensions>3</dimensions>
    </plugin>

    <!-- Motor Model Macro -->
    <xacro:macro name="motor_plugin" params="joint link direction id">
      <plugin filename="libgz-sim8-multicopter-motor-model-system.so"
              name="gz::sim::systems::MulticopterMotorModel">

        <robotNamespace>${robot_ns}</robotNamespace>
        <jointName>${joint}</jointName>
        <linkName>${link}</linkName>
        <turningDirection>${direction}</turningDirection>

        <maxRotVelocity>${max_rot_velocity}</maxRotVelocity>
        <motorConstant>${motor_constant}</motorConstant>      <!-- kf -->
        <momentConstant>${moment_constant}</momentConstant>   <!-- km -->

        <rotorDragCoefficient>${rotor_drag}</rotorDragCoefficient>
        <rollingMomentCoefficient>${rolling_moment}</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>${rotor_slowdown}</rotorVelocitySlowdownSim>

        <actuator_number>${id}</actuator_number>
        <commandSubTopic>gazebo/command/motor_speed</commandSubTopic>

        <motorType>velocity</motorType>
      </plugin>
    </xacro:macro>

    <!-- Correct Crazyflie Rotor Directions -->
    <xacro:motor_plugin joint="body_to_m1_prop" link="m1_prop" direction="cw"  id="0"/>
    <xacro:motor_plugin joint="body_to_m2_prop" link="m2_prop" direction="ccw" id="1"/>
    <xacro:motor_plugin joint="body_to_m3_prop" link="m3_prop" direction="cw"  id="2"/>
    <xacro:motor_plugin joint="body_to_m4_prop" link="m4_prop" direction="ccw" id="3"/>

  </gazebo>

  <!-- ================= IMU SENSOR ================= -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>500</update_rate>
      <topic>${robot_ns}/imu</topic>


      <imu>
        <linear_acceleration>true</linear_acceleration>
        <angular_velocity>true</angular_velocity>
      </imu>

      <plugin filename="libgz-sim8-imu-system.so"
              name="gz::sim::systems::Imu"/>
    </sensor>
  </gazebo>

</robot>
